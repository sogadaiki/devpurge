#!/usr/bin/env bash
# devpurge - Purge hidden dev caches on macOS
# https://github.com/sogadaiki/devpurge
#
# Usage: devpurge [OPTIONS]
# Run 'devpurge --help' for details.

set -euo pipefail

# ── Resolve script location (follows symlinks for Homebrew) ──────────────────
DEVPURGE_SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$DEVPURGE_SCRIPT" ]]; do
  DEVPURGE_LINK_DIR="$(cd "$(dirname "$DEVPURGE_SCRIPT")" && pwd)"
  DEVPURGE_SCRIPT="$(readlink "$DEVPURGE_SCRIPT")"
  [[ "$DEVPURGE_SCRIPT" != /* ]] && DEVPURGE_SCRIPT="${DEVPURGE_LINK_DIR}/${DEVPURGE_SCRIPT}"
done
DEVPURGE_DIR="$(cd "$(dirname "$DEVPURGE_SCRIPT")/.." && pwd)"

# ── Root detection (MUST run before loading libraries that use $HOME) ────────
DEVPURGE_IS_ROOT=0
if [[ "$(id -u)" -eq 0 ]]; then
  DEVPURGE_IS_ROOT=1
  # When running as root, $HOME may be /var/root. Use the real user's home.
  if [[ -n "${SUDO_USER:-}" ]]; then
    HOME=$(eval echo "~${SUDO_USER}")
    export HOME
  fi
fi
export DEVPURGE_IS_ROOT

# ── Load libraries ───────────────────────────────────────────────────────────
# shellcheck source=../lib/utils.sh
source "${DEVPURGE_DIR}/lib/utils.sh"
# shellcheck source=../lib/config.sh
source "${DEVPURGE_DIR}/lib/config.sh"
# shellcheck source=../lib/paths.sh
source "${DEVPURGE_DIR}/lib/paths.sh"
# shellcheck source=../lib/worktree.sh
source "${DEVPURGE_DIR}/lib/worktree.sh"
# shellcheck source=../lib/branches.sh
source "${DEVPURGE_DIR}/lib/branches.sh"
# shellcheck source=../lib/dupes.sh
source "${DEVPURGE_DIR}/lib/dupes.sh"
# shellcheck source=../lib/scan.sh
source "${DEVPURGE_DIR}/lib/scan.sh"
# shellcheck source=../lib/report.sh
source "${DEVPURGE_DIR}/lib/report.sh"
# shellcheck source=../lib/discover.sh
source "${DEVPURGE_DIR}/lib/discover.sh"
# shellcheck source=../lib/quarantine.sh
source "${DEVPURGE_DIR}/lib/quarantine.sh"
# shellcheck source=../lib/cleanup.sh
source "${DEVPURGE_DIR}/lib/cleanup.sh"
# shellcheck source=../lib/share.sh
source "${DEVPURGE_DIR}/lib/share.sh"

# ── Defaults ─────────────────────────────────────────────────────────────────
OPT_DRY_RUN=0
OPT_ALL=0
OPT_YES=0
OPT_SHARE=0
OPT_AI_ONLY=0
OPT_TRASH=0
OPT_JSON=0
OPT_DISCOVER=0

# ── Parse arguments ──────────────────────────────────────────────────────────
show_help() {
  cat <<'HELP'
devpurge - Purge hidden dev caches on macOS

USAGE
  devpurge [OPTIONS]
  devpurge quarantine <path> [reason]   Move a path into quarantine (30d grace)
  devpurge quarantine --list            Show quarantined items
  devpurge quarantine --restore <ID>    Restore an item to its original path
  devpurge quarantine --expire          Delete items past the grace period

OPTIONS
  -n, --dry-run       Scan only, don't delete anything
  -a, --all           Include caution-level caches (Notion, Discord, Slack, etc.)
  -y, --yes           Skip confirmation prompt
  -s, --share         Generate share text after cleanup
      --exclude P     Exclude path and everything under it (repeatable)
      --ai-only       Scan AI-era caches only (Claude, Cursor, uv, etc.)
      --trash         Move to ~/.Trash instead of deleting (recoverable)
      --json          Print scan results as JSON and exit (implies dry run)
      --discover      Show largest items under \$HOME (read-only) and exit
      --no-worktrees  Skip stale git worktree detection
      --no-color      Disable colored output
  -v, --version       Show version
  -h, --help          Show this help

EXAMPLES
  devpurge                  # Scan & clean dev caches (interactive)
  devpurge -n               # Dry run - just show what's there
  devpurge -y -s            # Auto-confirm + share results
  devpurge --ai-only -n     # Check AI tool caches only
  devpurge -a               # Include Notion/Discord/Slack caches
  devpurge --exclude ~/Projects/app/node_modules  # Skip specific path
  sudo devpurge -n          # Scan system-level caches (sleepimage, etc.)

CACHE TIERS
  AI-Era    Claude Code, Codex, Cursor, uv, Playwright, Puppeteer, Bun
  DevTool   npm, Homebrew, Chrome, VS Code, pip, Cargo, Gradle, Xcode
            + auto-detected app caches (Electron/Container/misc)
  Project   node_modules / .next in development projects (再インストールで復元)
  Worktree  merged/squash-merged & idle git worktrees (removed via git)
  Branch    local branches merged into main (git branch -d, SHAs logged)
  Caution   Notion, Discord, Slack, Adobe, Steam, AI models (--all to include)
  Review    large user data - reported only, NEVER deleted (Downloads,
            sessions, duplicates, files unopened 90d+)
  System    sleepimage, diagnostics, OS updates (sudo only)

SAFETY
  Paths containing 証拠/裁判/訴訟/準備書面/判決/原本 etc. are protected:
  devpurge refuses to delete or quarantine them, ever. Add your own with
  protect=SUBSTRING in ~/.devpurgerc.

CONFIG (~/.devpurgerc)
  exclude=~/path            # skip path and everything under it
  worktree_age_days=7       # idle days before merged worktrees are deletable
  worktree_auto=1           # allow worktree removal in unattended (-y) runs
  protect=SUBSTRING         # never touch paths containing SUBSTRING
  quarantine_days=30        # grace period before quarantined items expire
  stale_days=90             # "not opened in N days" report threshold

MORE INFO
  https://github.com/sogadaiki/devpurge
HELP
}

# ── Subcommand: devpurge quarantine ──────────────────────────────────────────
if [[ "${1:-}" == "quarantine" ]]; then
  shift
  devpurge_load_rc
  case "${1:-}" in
    --list|"")
      devpurge_quarantine_list
      exit $?
      ;;
    --restore)
      if [[ -z "${2:-}" ]]; then
        dp_error "Usage: devpurge quarantine --restore <ID>"
        exit 1
      fi
      devpurge_quarantine_restore "$2"
      exit $?
      ;;
    --expire)
      devpurge_quarantine_expire
      exit $?
      ;;
    -*)
      dp_error "Unknown quarantine option: $1"
      exit 1
      ;;
    *)
      _q_path="${1/#\~/$HOME}"
      shift
      devpurge_quarantine_add "$_q_path" "${*:-manual}"
      exit $?
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run)   OPT_DRY_RUN=1; shift ;;
    -a|--all)       OPT_ALL=1; shift ;;
    -y|--yes)       OPT_YES=1; shift ;;
    -s|--share)     OPT_SHARE=1; shift ;;
    --exclude)
      if [[ -z "${2:-}" ]]; then
        dp_error "--exclude requires a path argument"
        exit 1
      fi
      _exc_path="${2/#\~/$HOME}"
      _exc_path="${_exc_path%/}"
      DEVPURGE_EXCLUDES+=("$_exc_path")
      unset _exc_path
      shift 2
      ;;
    --ai-only)      OPT_AI_ONLY=1; shift ;;
    --trash)        OPT_TRASH=1; shift ;;
    --json)         OPT_JSON=1; export DEVPURGE_NO_COLOR=1; shift ;;
    --discover)     OPT_DISCOVER=1; shift ;;
    --no-worktrees) export DEVPURGE_SKIP_WORKTREES=1; shift ;;
    --no-color)     export DEVPURGE_NO_COLOR=1; shift ;;
    -v|--version)   echo "devpurge ${DEVPURGE_VERSION}"; exit 0 ;;
    -h|--help)      show_help; exit 0 ;;
    *)
      dp_error "Unknown option: $1"
      dp_error "Run 'devpurge --help' for usage."
      exit 1
      ;;
  esac
done

# Re-source utils if --no-color was set (to update color variables)
if [[ "${DEVPURGE_NO_COLOR:-}" == "1" ]]; then
  source "${DEVPURGE_DIR}/lib/utils.sh"
fi

# ── Load config file ─────────────────────────────────────────────────────────
devpurge_load_rc

# ── macOS check ──────────────────────────────────────────────────────────────
if [[ "$(uname)" != "Darwin" ]]; then
  dp_error "devpurge is designed for macOS only."
  exit 1
fi

# ── Discover mode: read-only disk overview, then exit ────────────────────────
if [[ $OPT_DISCOVER -eq 1 ]]; then
  printf "\n"
  dp_bold "  devpurge v${DEVPURGE_VERSION} — discover"
  printf "\n"
  devpurge_discover
  exit 0
fi

# ── Banner ───────────────────────────────────────────────────────────────────
if [[ $OPT_JSON -eq 0 ]]; then
  printf "\n"
  dp_bold "  devpurge v${DEVPURGE_VERSION}"
  dp_dim "  Purge hidden dev caches on macOS"
  if [[ "$DEVPURGE_IS_ROOT" -eq 1 ]]; then
    dp_warn "  Running as root — system-level caches enabled"
  fi
  printf "\n"
fi

# ── Phase 1: Scan ────────────────────────────────────────────────────────────
scan_mode="default"
if [[ $OPT_AI_ONLY -eq 1 ]]; then
  scan_mode="ai"
elif [[ $OPT_ALL -eq 1 ]]; then
  scan_mode="all"
fi

if [[ $OPT_JSON -eq 1 ]]; then
  devpurge_scan "$scan_mode" >/dev/null 2>&1
  devpurge_report_json
  exit 0
fi

devpurge_scan "$scan_mode"

# ── Phase 2: Report ──────────────────────────────────────────────────────────
if ! devpurge_report; then
  exit 0
fi

# ── Dry run: stop here ───────────────────────────────────────────────────────
if [[ $OPT_DRY_RUN -eq 1 ]]; then
  devpurge_quarantine_expire dry
  dp_dim "  Dry run mode - nothing was deleted."
  dp_dim "  Run without -n to clean up."
  printf "\n"
  exit 0
fi

# ── Phase 3: Confirm ─────────────────────────────────────────────────────────
selection="all"

if [[ $OPT_YES -eq 0 ]]; then
  printf "\n"
  printf "  ${CLR_BOLD}Delete these caches?${CLR_RESET}\n"
  printf "\n"
  printf "  ${CLR_BOLD}1${CLR_RESET}) Delete all listed items\n"
  printf "  ${CLR_BOLD}2${CLR_RESET}) Select specific IDs (e.g. A01,A04,D02)\n"
  printf "  ${CLR_BOLD}3${CLR_RESET}) Cancel\n"
  printf "\n"
  printf "  Choice [1-3]: "
  read -r choice

  case "$choice" in
    1|"")
      selection="all"
      ;;
    2)
      printf "  Enter IDs (comma-separated): "
      read -r selection
      selection="${selection// /}"
      if [[ -z "$selection" ]]; then
        dp_warn "  No IDs entered. Cancelled."
        exit 0
      fi
      ;;
    3)
      dp_info "  Cancelled. Nothing was deleted."
      exit 0
      ;;
    *)
      dp_info "  Cancelled. Nothing was deleted."
      exit 0
      ;;
  esac
fi

# ── Phase 4: Execute ─────────────────────────────────────────────────────────
devpurge_cleanup "$selection"
devpurge_quarantine_expire
devpurge_cleanup_summary

# ── Phase 5: Share ───────────────────────────────────────────────────────────
if [[ $OPT_SHARE -eq 1 && $CLEANUP_DELETED -gt 0 ]]; then
  devpurge_share
elif [[ $CLEANUP_DELETED -gt 0 ]]; then
  printf "  ${CLR_DIM}Tip: Run with --share to generate a shareable summary${CLR_RESET}\n"
  printf "\n"
fi
